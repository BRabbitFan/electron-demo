{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Node Launch",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
      },
      "args": [
        "."
      ],
      "outputCapture": "std"
    },
    {
      "name": "LLDB Attach",
      "type": "lldb",
      "request": "attach",
      "pid": "${command:pickProcess}"
    }
  ],
  "compounds": [
    {
      "name": "Node Launch & LLDB Attach",
      "configurations": [
        "Node Launch",
        "LLDB Attach"
      ]
    }
  ]
}
